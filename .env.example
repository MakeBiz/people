# ============================================================
#  HR Testing Platform — пример переменных окружения
#  Скопируйте в .env и заполните реальными значениями.
#  .env в .gitignore и НИКОГДА не коммитится.
# ============================================================

# --- PostgreSQL ---
POSTGRES_USER=hr
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=hr_testing
# DATABASE_URL используют и бот, и админка, и Prisma.
# Хост 'postgres' = имя сервиса в docker-compose.
DATABASE_URL=postgresql://hr:change_me_strong_password@postgres:5432/hr_testing?schema=public

# --- Telegram bot ---
# Токен от @BotFather
BOT_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
# Username бота без @ (для генерации deep-link t.me/<username>?start=<token>)
BOT_USERNAME=my_hr_testing_bot
# Режим работы бота: polling | webhook
BOT_MODE=polling
# Только для webhook: публичный URL, на который Telegram шлёт апдейты
BOT_WEBHOOK_URL=https://bot.example.com
# Секрет для проверки заголовка вебхука (любая случайная строка)
BOT_WEBHOOK_SECRET=change_me_webhook_secret

# --- Next.js админка / NextAuth ---
# openssl rand -base64 32
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=https://admin.example.com
# Учётка владельца, создаётся сидом при первом запуске
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=change_me_owner_password

# --- Caddy / домены ---
ADMIN_DOMAIN=admin.example.com
BOT_DOMAIN=bot.example.com
# Email для Let's Encrypt
ACME_EMAIL=admin@example.com

# --- Claude API (генерация текстов: тёплое резюме сотруднику + профиль руководителю) ---
# Без ключа функция мягко отключается (бот покажет обычный outro, карточка — слотовую сводку).
ANTHROPIC_API_KEY=
